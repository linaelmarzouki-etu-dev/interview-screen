# Mode: interview (audio) or mcq (screenshot vision)
MODE=interview

# Groq (recommended — fast inference, OpenAI-compatible)
GROQ_API_KEY=gsk-your-key-here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
TRANSCRIBE_MODEL=whisper-large-v3-turbo
CHAT_MODEL=llama-3.3-70b-versatile
VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
MCQ_REASONING_MODEL=llama-3.3-70b-versatile
MCQ_REASONING_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-120b,qwen/qwen3-32b
MCQ_TWO_STEP=true
MCQ_ANSWER_ONLY=true
MCQ_ALLOW_DESKTOP_GRAB=true
SCREEN_MONITOR=auto

# Licensing (MCQ SaaS)
LICENSE_REQUIRED=true
LICENSE_DB_PATH=data/licenses.db
LICENSE_PEPPER=change-me-to-a-long-random-string
LICENSE_ADMIN_PASSWORD=your-admin-password
GUMROAD_WEBHOOK_SECRET=
PUBLIC_URL=http://139.84.130.152:8765

# Or use OpenAI directly (set OPENAI_API_KEY instead of GROQ_API_KEY)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# TRANSCRIBE_MODEL=whisper-1
# CHAT_MODEL=gpt-4o-mini

# Your interview context (used to personalize answers)
ROLE=Software Engineer
RESUME_SUMMARY=5 years Python/backend, distributed systems, AWS
EXTRA_CONTEXT=Focus on concise spoken answers, STAR format when behavioral

# Server
HOST=0.0.0.0
PORT=8765

# Audio device (leave empty for auto-detect)
# Linux: PipeWire monitor name/id  (pw-record / pactl)
# Windows: WASAPI loopback index or partial device name
# Run: python -m interview_assistent --list-devices
AUDIO_DEVICE=

# Chunk length in seconds before sending audio for transcription
AUDIO_CHUNK_SECONDS=6

# Auto-generate answer when a new question is detected
AUTO_ANSWER=true